[global]
member-list = members.xlsx

[gerrit]
gerrit-url = <gerrit-url, e.g. http://my.gerrit.com/>
username = <your username>
password = <your password>

[gitlab]
gitlab-url = <gitlab url, e.g. https://gitlab.com>
token = <token>
branch = <branch>

[codehub]
codehub-url = <codehub url, e.g. https://codehub.com/>
token = <token>
project = <project>
branch = <branch>

[jira]
jira-url = <jira url, e.g. https://jira.com/
username = <your username>
password = <your password>

[sharepoint]
sharepoint-url = <sharepoint url, e.g. http://office.com/>
documents_folder = <some_root>
username = <your username>
password = <your password>

[gitee]
per_page = 20
pause_after_requests = 5
pause_duration = 3
gitee-url = https://gitee.com
# get new token here
token = <token>
# format for repository:
repository = openharmony/arkui_ace_engine,openharmony-sig/arkcompiler_ets_frontend
branch = master

[gitcode]
per_page = 70
pause_after_requests = 10
pause_duration = 6
gitcode-url = https://gitcode.com/
# get new token here https://gitcode.com/setting/token-classic
token = <token>
# format for repository:
repository = OH_003/arkui_ace_engine
branch = master

[proxy]
# Optional: Proxy configuration for all API requests
# If not set, will use HTTP_PROXY/HTTPS_PROXY environment variables
# For URLs with special characters in password, use URL encoding:
#   @ -> %40
#   : -> %3A
#   / -> %2F
#   % -> %25 (double % to escape)
# Example: http://username:password%40@proxy.example.com:8080
# http = http://proxy.example.com:8080
# https = https://proxy.example.com:8080
# no_proxy = localhost,127.0.0.1,.local

[ssl]
# Optional: SSL certificate verification settings
# verify = true
# bundle_ca = bundle-ca
# check_hostname = true
# 
# If bundle-ca causes "basic constraints" or "CERTIFICATE_VERIFY_FAILED" errors:
# 1. The code now uses urllib3 custom SSL context which is more lenient
# 2. Try using a different bundle-ca file (re-export from your CA)
# 3. Set check_hostname = false (less secure, but may help with some certificates)
# 4. Set verify = false (NOT RECOMMENDED, completely disables SSL verification)
# 5. Leave unset to use default system certificates (if bundle-ca not found)

[ollama]
# Local Ollama endpoint
url = http://localhost:11434
# Optional API key for proxy/gateway deployments
api_key =
# Example model: qwen2.5:14b
model =
timeout_seconds = 60
temperature = 0.2
enabled = true

[jira_weekly_email]
# Optional default project, can be overridden with --params project=ABC
project =
output_dir = reports
snapshot_dir = reports/snapshots/jira_weekly_email
vacation_file =
vacation_sheet = Vacations2026
vacation_marker_values = p,P
vacation_horizon_days = 60
priority_high_values = High,Highest
labels_highlights = highlights
# Epic inclusion filter labels for weekly email report.
# Default: report
# Special value: @all -> include issues with any labels (disables label filtering).
labels_report = report
title_main = TelmaST Weekly Report
chapter_highlights_title = Highlights
chapter_results_title = Key Results and Achievements
chapter_next_week_title = Next Week Plans
chapter_vacations_title = Vacations (next 60 days)
chapter_results_high_priority_subtitle = High priority items
chapter_results_bugs_subtitle = Bugs summary
console_diff_title = Changes vs Previous Week
bugs_summary_template_closed_in_progress = {closed} trouble reports/issues are analyzed and closed, {in_progress} currently in progress.
