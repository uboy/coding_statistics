{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Stats: Setup Config",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/stats_main.py",
            "console": "integratedTerminal",
            "args": [
                "setup",
                "--config",
                "configs/local/config.ini"
            ]
        },
        {
            "name": "Stats: Unified Review (Current Month)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/stats_main.py",
            "console": "integratedTerminal",
            "args": [
                "run",
                "--config",
                "configs/local/config.ini",
                "--report",
                "unified_review",
                "--start",
                "2026-02-01",
                "--end",
                "2026-02-20",
                "--output-formats",
                "excel",
                "word",
                "--params",
                "output_dir=reports"
            ]
        },
        {
            "name": "Stats: Jira Weekly (Current Month)",
